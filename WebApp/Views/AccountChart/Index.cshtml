@model IEnumerable<WebApp.ViewModels.View_ChartLedgerAccount.LedgerAccount>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

@*<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>*@

<div class="row">


    <div class="card shadow w-100">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>

                            <th>@Html.DisplayNameFor(model => model.AccountNo)</th>
                            <th>@Html.DisplayNameFor(model => model.Name)</th>
                            <th>@Html.DisplayNameFor(model => model.Balance)</th>
                            <th>@Html.DisplayNameFor(model => model.IncomeBalance)</th>
                            <th>@Html.DisplayNameFor(model => model.AccountType)</th>
                            <th></th>

                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in Model)
                        {

                            <tr>

                                <td>@Html.DisplayFor(model => item.AccountNo)</td>
                                <td>@Html.DisplayFor(model => item.Name)</td>
                                <td>@Html.DisplayFor(model => item.Balance)</td>
                                <td>@Html.DisplayFor(model => item.IncomeBalance)</td>
                                <td>@Html.DisplayFor(model => item.AccountType)</td>

                                <td>

                                    @Html.ActionLink("Edit", "Edit", new { id = item.LedgerID }) 

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>

            <div class="text-left">

                <a asp-controller="AccountChart" asp-action="Create" class="btn btn-primary">Add New Ledger Account</a>

            </div>

        </div>
    </div>



</div>







