@model IEnumerable<WebApp.ViewModels.View_Companys.GetCompanys>

@*@model IEnumerable<WebApp.Models.Dto.Companys.Company>*@

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}



@*<p>
    <a asp-action="Create">Create New</a>
</p>*@
<div class="row">

    
        <div class="card shadow w-100">
           
            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                        <thead>
                            <tr>

                                <th>@Html.DisplayNameFor(model => model.Name)</th>
                                <th>@Html.DisplayNameFor(model => model.Email)</th>
                                <th>@Html.DisplayNameFor(model => model.PhoneNo)</th>
                                <th>@Html.DisplayNameFor(model => model.ContactName)</th>
                                <th>@Html.DisplayNameFor(model => model.isDefault)</th>
                                <th></th>

                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var item in Model)
                            {

                            <tr>

                                <td>@Html.DisplayFor(model => item.Name)</td>
                                <td>@Html.DisplayFor(model => item.Email)</td>
                                <td>@Html.DisplayFor(model => item.PhoneNo)</td>
                                <td>@Html.DisplayFor(model => item.ContactName)</td>
                                <td>@Html.DisplayFor(model => item.isDefault)</td>

                                <td>

                                    @Html.ActionLink("Edit", "Edit", new { id = item.CompanyID }) | 

                                    @Html.ActionLink("Set Default", "SetDefault", new { id = item.CompanyID })

                                    

                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>

                </div>

                <div class="text-left">
                    
                    <a asp-controller="Company" asp-action="Create" asp-route-id="1" class="btn btn-primary">Add New Company</a>

                </div>

            </div>
        </div>
    
        

</div>
